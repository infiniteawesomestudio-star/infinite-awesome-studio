# Copy this file to .env and fill in values.
# For local dev without the proxy, also create .env.local (see below).
# Never commit .env or .env.local — both are in .gitignore.

# --- PRODUCTION (required) ---
VITE_WORKER_URL=https://benebots-proxy.YOUR-SUBDOMAIN.workers.dev
VITE_WORKER_TOKEN=your-shared-secret-token-here

# --- LOCAL DEV ONLY (.env.local, higher priority than .env) ---
# Only used when VITE_WORKER_URL is not set.
# VITE_ANTHROPIC_API_KEY=sk-ant-...
