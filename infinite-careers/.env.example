# Copy this file to .env.local for internal LIVE mode.
# Never commit .env or .env.local — both are in .gitignore.
#
# The PUBLIC demo build needs none of these — it ships with VITE_DEMO_MODE=true
# and makes zero API calls (renders the baked-in DEMO_RESULT).

# --- INTERNAL LIVE MODE (Ty, localhost only) ---
# Routes Claude calls through the benebots-proxy worker (API key stays server-side).
VITE_WORKER_URL=https://benebots-proxy.YOUR-SUBDOMAIN.workers.dev
VITE_WORKER_TOKEN=your-shared-secret-token-here

# true  = canned public demo, no network calls (this is what the public build uses)
# false = live mode: real analysis via the worker (internal use)
VITE_DEMO_MODE=false
